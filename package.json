{
  "name": "codemeet",
  "version": "0.1.0",
  "private": true,
  "description": "Real-time collaborative coding in VS Code over P2P WebRTC",
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.{ts,json,md,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md,yaml}\"",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run",
    "clean": "pnpm -r run clean"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  }
}
