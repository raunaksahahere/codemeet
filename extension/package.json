{
  "name": "codemeet",
  "displayName": "CodeMeet",
  "description": "Real-time collaborative coding in VS Code over peer-to-peer WebRTC",
  "version": "0.1.0",
  "publisher": "raunaksahahere",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/raunaksahahere/codemeet"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Education"
  ],
  "icon": "codemeet.png",
  "keywords": [
    "collaboration",
    "real-time",
    "pair-programming",
    "webrtc",
    "live-coding"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "package": "vsce package --no-dependencies",
    "clean": "rimraf dist"
  },
  "contributes": {
    "commands": [
      {
        "command": "codemeet.startRoom",
        "title": "CodeMeet: Start Room",
        "icon": "$(broadcast)"
      },
      {
        "command": "codemeet.joinRoom",
        "title": "CodeMeet: Join Room",
        "icon": "$(plug)"
      },
      {
        "command": "codemeet.leaveRoom",
        "title": "CodeMeet: Leave Room",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "codemeet.openSharedNotes",
        "title": "CodeMeet: Open Shared Notes",
        "icon": "$(note)"
      },
      {
        "command": "codemeet.openPrivateNotes",
        "title": "CodeMeet: Open Private Notes",
        "icon": "$(lock)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codemeet-sidebar",
          "title": "CodeMeet",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "codemeet-sidebar": [
        {
          "type": "webview",
          "id": "codemeet.sidebarView",
          "name": "CodeMeet"
        }
      ]
    },
    "configuration": {
      "title": "CodeMeet",
      "properties": {
        "codemeet.serverUrl": {
          "type": "string",
          "default": "http://localhost:3001",
          "description": "URL of the CodeMeet signaling server"
        }
      }
    }
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@codemeet/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "ignore": "^7.0.5",
    "nanoid": "^3.3.11",
    "socket.io-client": "^4.8.3",
    "yjs": "^13.6.30"
  }
}
